APP_NAME="PRX Backend"
APP_VERSION="1.0.0"
PORT=3000
API_PREFIX=prx

DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl-mode=REQUIRED"

JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

MAIL_HOST="smtp.example.com"
MAIL_PORT=587
MAIL_USER="user@example.com"
MAIL_PASS="mail-password"
MAIL_FROM="PRX <user@example.com>"

TIGRIS_STORAGE_ACCESS_KEY_ID="change-me"
TIGRIS_STORAGE_SECRET_ACCESS_KEY="change-me"
TIGRIS_STORAGE_ENDPOINT="https://fly.storage.tigris.dev"
TIGRIS_PUBLIC_BUCKET="prx-bucket-public"
TIGRIS_PRIVATE_BUCKET="prx-bucket-private"

THROTTLE_TTL=60000
THROTTLE_LIMIT=20
