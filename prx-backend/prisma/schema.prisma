// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  estandar
  metaadministrador
}

enum RepositoryVisibility {
  publico
  privado
  intimo
}

enum InvitationStatus {
  pendiente
  aceptada
  rechazada
  cancelada
}

enum NotificationType {
  invitacion_repositorio
}

// ======================================================
// BLOQUE 1 — Usuarios, perfil y catalogos
// ======================================================

model User {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs

  // Atributos requeridos
  username  String @unique @db.VarChar(15)
  email     String @unique @db.VarChar(50)
  password  String @db.VarChar(255)
  role      Role   @default(estandar)
  avatarUrl String @db.VarChar(255)

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  profile                       Profile?
  binnacles                     Binnacle[]
  sessions                      Session[]
  ownedRepositories             Repository[]           @relation("RepositoryOwner")
  repositoryUsers               RepositoryUser[]
  sentRepositoryInvitations     RepositoryInvitation[] @relation("RepositoryInvitationSender")
  receivedRepositoryInvitations RepositoryInvitation[] @relation("RepositoryInvitationInvited")
  sentNotifications             Notification[]         @relation("NotificationSender")
  receivedNotifications         Notification[]         @relation("NotificationReceiver")

  createdRepositories Repository[] @relation("RepositoryCreatedBy")
  updatedRepositories Repository[] @relation("RepositoryUpdatedBy")
  createdFolders      Folder[]     @relation("FolderCreatedBy")
  updatedFolders      Folder[]     @relation("FolderUpdatedBy")
  createdFiles        File[]       @relation("FileCreatedBy")
  updatedFiles        File[]       @relation("FileUpdatedBy")
  createdNotes        Note[]       @relation("NoteCreatedBy")
  updatedNotes        Note[]       @relation("NoteUpdatedBy")

  @@index([email, status])
}

model Profile {
  // PK
  id Int @id @db.UnsignedInt

  // FKs
  phoneCodeId Int? @db.UnsignedInt
  countryId   Int? @db.UnsignedTinyInt
  regionId    Int? @db.UnsignedInt
  townId      Int? @db.UnsignedInt

  // Atributos requeridos
  isEmailVisible Boolean @default(false)

  // Atributos opcionales
  firstName      String? @db.VarChar(60)
  lastName       String? @db.VarChar(60)
  secondLastName String? @db.VarChar(60)
  biography      String? @db.VarChar(2000)
  phoneNumber    String? @db.VarChar(20)

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  user                  User                   @relation(fields: [id], references: [id])
  phoneCode             PhoneCode?             @relation(fields: [phoneCodeId], references: [id])
  country               Country?               @relation(fields: [countryId], references: [id])
  region                Region?                @relation(fields: [regionId], references: [id])
  town                  Town?                  @relation(fields: [townId], references: [id])
  profileSocialNetworks ProfileSocialNetwork[]
  tagProfiles           TagProfile[]

  @@index([phoneCodeId])
  @@index([countryId])
  @@index([regionId])
  @@index([townId])
}

model Continent {
  // PK
  id Int @id @db.UnsignedTinyInt

  // FKs

  // Atributos requeridos
  name String @db.VarChar(20)

  // Atributos opcionales

  // Auditoría

  // Relaciones
  countries Country[]
}

model Country {
  // PK
  id Int @id @db.UnsignedTinyInt

  // FKs
  continentId Int @db.UnsignedTinyInt

  // Atributos requeridos
  name String @db.VarChar(50)

  // Atributos opcionales

  // Auditoría
  status Int @default(1) @db.UnsignedTinyInt

  // Relaciones
  continent  Continent   @relation(fields: [continentId], references: [id])
  profiles   Profile[]
  phoneCodes PhoneCode[]

  @@index([continentId])
}

model Region {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs

  // Atributos requeridos
  name String @db.VarChar(50)

  // Atributos opcionales

  // Auditoría
  status Int @default(1) @db.UnsignedTinyInt

  // Relaciones
  profiles Profile[]
}

model Town {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs

  // Atributos requeridos
  name String @db.VarChar(50)

  // Atributos opcionales

  // Auditoría
  status Int @default(1) @db.UnsignedTinyInt

  // Relaciones
  profiles Profile[]
}

model PhoneCode {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  countryId Int @db.UnsignedTinyInt

  // Atributos requeridos
  code String @db.VarChar(6)

  // Atributos opcionales

  // Auditoría
  status Int @default(1) @db.UnsignedTinyInt

  // Relaciones
  country  Country   @relation(fields: [countryId], references: [id])
  profiles Profile[]

  @@index([countryId])
}

model SocialNetwork {
  // PK
  id Int @id @db.UnsignedTinyInt

  // FKs

  // Atributos requeridos
  name    String @db.VarChar(40)
  baseUrl String @db.VarChar(100)
  icon    String @db.VarChar(100)

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  profileSocialNetworks ProfileSocialNetwork[]
}

model ProfileSocialNetwork {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  profileId       Int @db.UnsignedInt
  socialNetworkId Int @db.UnsignedTinyInt

  // Atributos requeridos
  username String @db.VarChar(255)

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  profile       Profile       @relation(fields: [profileId], references: [id])
  socialNetwork SocialNetwork @relation(fields: [socialNetworkId], references: [id])

  @@index([profileId])
  @@index([socialNetworkId])
}

model Tag {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs

  // Atributos requeridos
  name String @unique @db.VarChar(25)

  // Atributos opcionales

  // Auditoría
  status Int @default(1) @db.UnsignedTinyInt

  // Relaciones
  tagProfiles     TagProfile[]
  tagFiles        TagFile[]
  tagRepositories TagRepository[]
}

model TagProfile {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  profileId Int @db.UnsignedInt
  tagId     Int @db.UnsignedInt

  // Atributos requeridos

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  profile Profile @relation(fields: [profileId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@unique([profileId, tagId])
  @@index([profileId])
  @@index([tagId])
}

model Binnacle {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  userId Int @db.UnsignedInt

  // Atributos requeridos
  name    String @db.VarChar(15)
  content String @db.VarChar(2000)

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ======================================================
// BLOQUE 2 — Repositorios y membresias
// ======================================================

model Repository {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  repositoryCategoryId Int @db.UnsignedInt
  ownerUserId          Int @db.UnsignedInt

  // Atributos requeridos
  name       String               @db.VarChar(100)
  visibility RepositoryVisibility @default(privado)
  color      String               @db.Char(6)

  // Atributos opcionales
  description String? @db.VarChar(1500)

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repositoryCategory    RepositoryCategory     @relation(fields: [repositoryCategoryId], references: [id])
  ownerUser             User                   @relation("RepositoryOwner", fields: [ownerUserId], references: [id])
  createdByUser         User                   @relation("RepositoryCreatedBy", fields: [createdBy], references: [id])
  updatedByUser         User?                  @relation("RepositoryUpdatedBy", fields: [updatedBy], references: [id])
  repositoryUsers       RepositoryUser[]
  repositoryInvitations RepositoryInvitation[]
  folders               Folder[]
  files                 File[]
  tagRepositories       TagRepository[]
  notes                 Note[]

  @@index([repositoryCategoryId])
  @@index([ownerUserId])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([ownerUserId, status, name], name: "repository_owner_status_name_idx")
  @@index([ownerUserId, visibility, status, updatedAt, id], name: "repository_owner_visibility_status_updated_idx")
  @@index([status, visibility, updatedAt, id], name: "repository_status_visibility_updated_idx")
}

model RepositoryCategory {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs

  // Atributos requeridos
  name String @unique @db.VarChar(50)

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repositories Repository[]
}

model RepositoryRole {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs

  // Atributos requeridos
  name String @unique @db.VarChar(30)

  // Atributos opcionales
  description String? @db.VarChar(255)

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repositoryUsers       RepositoryUser[]
  repositoryInvitations RepositoryInvitation[]
}

model RepositoryFunction {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs

  // Atributos requeridos
  name String @unique @db.VarChar(30)

  // Atributos opcionales
  description String? @db.VarChar(255)

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repositoryUsers       RepositoryUser[]
  repositoryInvitations RepositoryInvitation[]
}

model RepositoryUser {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  repositoryId         Int @db.UnsignedInt
  userId               Int @db.UnsignedInt
  repositoryRoleId     Int @db.UnsignedInt
  repositoryFunctionId Int @db.UnsignedInt

  // Atributos requeridos

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repository         Repository         @relation(fields: [repositoryId], references: [id])
  user               User               @relation(fields: [userId], references: [id])
  repositoryRole     RepositoryRole     @relation(fields: [repositoryRoleId], references: [id])
  repositoryFunction RepositoryFunction @relation(fields: [repositoryFunctionId], references: [id])

  @@unique([repositoryId, userId])
  @@index([repositoryId])
  @@index([userId])
  @@index([repositoryRoleId])
  @@index([repositoryFunctionId])
}

// ======================================================
// BLOQUE 3 — Invitaciones y notificaciones
// ======================================================

model RepositoryInvitation {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  repositoryId         Int @db.UnsignedInt
  senderUserId         Int @db.UnsignedInt
  invitedUserId        Int @db.UnsignedInt
  repositoryRoleId     Int @db.UnsignedInt
  repositoryFunctionId Int @db.UnsignedInt

  // Atributos requeridos
  invitationStatus InvitationStatus @default(pendiente)

  // Atributos opcionales
  welcomeMessage String? @db.VarChar(2000)

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repository         Repository         @relation(fields: [repositoryId], references: [id])
  senderUser         User               @relation("RepositoryInvitationSender", fields: [senderUserId], references: [id])
  invitedUser        User               @relation("RepositoryInvitationInvited", fields: [invitedUserId], references: [id])
  repositoryRole     RepositoryRole     @relation(fields: [repositoryRoleId], references: [id])
  repositoryFunction RepositoryFunction @relation(fields: [repositoryFunctionId], references: [id])

  @@index([repositoryId])
  @@index([senderUserId])
  @@index([invitedUserId])
  @@index([repositoryRoleId])
  @@index([repositoryFunctionId])
}

model Notification {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  senderUserId   Int @db.UnsignedInt
  receiverUserId Int @db.UnsignedInt

  // Atributos requeridos
  title       String           @db.VarChar(150)
  type        NotificationType
  referenceId Int              @db.UnsignedInt
  isRead      Boolean          @default(false)

  // Atributos opcionales
  message String? @db.VarChar(2000)

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  senderUser   User @relation("NotificationSender", fields: [senderUserId], references: [id])
  receiverUser User @relation("NotificationReceiver", fields: [receiverUserId], references: [id])

  @@index([senderUserId])
  @@index([receiverUserId])
  @@index([referenceId])
}

// ======================================================
// BLOQUE 4 — Carpetas, archivos y tags
// ======================================================

model Folder {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  repositoryId Int  @db.UnsignedInt
  parentId     Int? @db.UnsignedInt

  // Atributos requeridos
  name  String @db.VarChar(100)
  path  String @db.Text
  level Int    @db.UnsignedInt
  color String @db.Char(6)

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repository    Repository @relation(fields: [repositoryId], references: [id])
  parent        Folder?    @relation("FolderToFolder", fields: [parentId], references: [id])
  createdByUser User       @relation("FolderCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User?      @relation("FolderUpdatedBy", fields: [updatedBy], references: [id])
  children      Folder[]   @relation("FolderToFolder")
  files         File[]

  @@index([repositoryId])
  @@index([parentId])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([repositoryId, parentId, status, name], name: "folder_repo_parent_status_name_idx")
}

model File {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  repositoryId Int  @db.UnsignedInt
  folderId     Int? @db.UnsignedInt

  // Atributos requeridos
  name        String @db.VarChar(255)
  extension   String @db.VarChar(10)
  mimeType    String @db.VarChar(100)
  size        Int    @db.UnsignedInt
  storagePath String @db.Text

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repository    Repository @relation(fields: [repositoryId], references: [id])
  folder        Folder?    @relation(fields: [folderId], references: [id])
  createdByUser User       @relation("FileCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User?      @relation("FileUpdatedBy", fields: [updatedBy], references: [id])
  tagFiles      TagFile[]

  @@index([repositoryId])
  @@index([folderId])
  @@index([createdBy])
  @@index([updatedBy])
  @@index([repositoryId, folderId, status, name, extension], name: "file_repo_folder_status_name_ext_idx")
}

model TagFile {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  fileId Int @db.UnsignedInt
  tagId  Int @db.UnsignedInt

  // Atributos requeridos

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  file File @relation(fields: [fileId], references: [id])
  tag  Tag  @relation(fields: [tagId], references: [id])

  @@unique([fileId, tagId])
  @@index([fileId])
  @@index([tagId])
}

model TagRepository {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  repositoryId Int @db.UnsignedInt
  tagId        Int @db.UnsignedInt

  // Atributos requeridos

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repository Repository @relation(fields: [repositoryId], references: [id])
  tag        Tag        @relation(fields: [tagId], references: [id])

  @@unique([repositoryId, tagId])
  @@index([repositoryId])
  @@index([tagId])
}

// ======================================================
// BLOQUE 5 — Notas y adjuntos de notas
// ======================================================

model Note {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  repositoryId Int @db.UnsignedInt

  // Atributos requeridos
  title   String @db.VarChar(150)
  content String @db.Text

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  repository    Repository @relation(fields: [repositoryId], references: [id])
  createdByUser User       @relation("NoteCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User?      @relation("NoteUpdatedBy", fields: [updatedBy], references: [id])
  noteFiles     NoteFile[]

  @@index([repositoryId])
  @@index([createdBy])
  @@index([updatedBy])
}

model NoteFile {
  // PK
  id Int @id @default(autoincrement()) @db.UnsignedInt

  // FKs
  noteId Int @db.UnsignedInt

  // Atributos requeridos
  name        String @db.VarChar(255)
  storagePath String @db.Text

  // Atributos opcionales

  // Auditoría
  status    Int      @default(1) @db.UnsignedTinyInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int      @db.UnsignedInt
  updatedBy Int?     @db.UnsignedInt

  // Relaciones
  note Note @relation(fields: [noteId], references: [id])

  @@index([noteId])
}

// ======================================================
// BLOQUE 6 — Sesion, tokens y codigos
// ======================================================

model Session {
  id         String    @id @default(uuid()) @db.Char(36)
  userId     Int       @db.UnsignedInt
  userAgent  String?   @db.VarChar(255)
  ipAddress  String?   @db.VarChar(45)
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user          User           @relation(fields: [userId], references: [id])
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([revokedAt])
}

model VerificationCode {
  id           String    @id @default(uuid()) @db.Char(36)
  email        String    @db.VarChar(150)
  username     String    @db.VarChar(50)
  passwordHash String    @db.VarChar(255)
  code         String    @db.VarChar(6)
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([email])
}

model PasswordReset {
  id        String    @id @default(uuid()) @db.Char(36)
  email     String    @db.VarChar(150)
  code      String    @db.VarChar(6)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Char(36)
  sessionId String    @db.Char(36)
  token     String    @db.Text
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  session Session @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([revokedAt])
}
