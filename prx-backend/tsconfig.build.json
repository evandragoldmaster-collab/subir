{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@config/*": ["./src/config/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/*": ["./src/shared/*"],
      "@generated-prisma/*": ["./generated/prisma/*"]
    }
  },
  "exclude": ["node_modules", "test", "dist", "**/*spec.ts", "prisma.config.ts"]
}